// pages/attendance/[tab].js
import { useRouter } from 'next/router'
import { useEffect, useState } from 'react'
import AttendancePage from './index'
import RegularizationMyRequests from './regularization/my-requests'
import RegularizationApprovals from './regularization/approvals'
import TabPanel from '@mui/lab/TabPanel'
import TabContext from '@mui/lab/TabContext'
import TabList from '@mui/lab/TabList'
import Tab from '@mui/material/Tab'
import Box from '@mui/material/Box'
import Typography from '@mui/material/Typography'
import Icon from 'src/@core/components/icon'

const VALID_TABS = ['records', 'regularise', 'approvals']

const AttendanceTabRouter = () => {
  const router = useRouter()
  const { tab } = router.query
  const [activeTab, setActiveTab] = useState('records')

  useEffect(() => {
    if (!tab) {
      setActiveTab('records')
    } else if (VALID_TABS.includes(tab)) {
      setActiveTab(tab)
    } else {
      router.replace('/attendance/records')
    }
  }, [tab, router])

  if (!router.isReady) return null

  const handleChange = (event, newValue) => {
    router.push(`/attendance/${newValue}`)
  }

  return (
    <TabContext value={activeTab}>
      <Box sx={{ borderBottom: 1, borderColor: 'divider', mb: 3 }}>
        <TabList onChange={handleChange} aria-label='attendance tabs'>
          <Tab 
            label={
              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <Icon icon='tabler:clock-check' fontSize={18} />
                <span>Attendance Records</span>
              </Box>
            } 
            value='records' 
          />
          <Tab 
            label={
              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <Icon icon='tabler:edit' fontSize={18} />
                <span>My Regularisations</span>
              </Box>
            } 
            value='regularise' 
          />
          <Tab 
            label={
              <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                <Icon icon='tabler:check' fontSize={18} />
                <span>Approvals</span>
              </Box>
            } 
            value='approvals' 
          />
        </TabList>
      </Box>
      
      <TabPanel value='records' sx={{ p: 0 }}>
        <AttendancePage />
      </TabPanel>
      <TabPanel value='regularise' sx={{ p: 0 }}>
        <RegularizationMyRequests />
      </TabPanel>
      <TabPanel value='approvals' sx={{ p: 0 }}>
        <RegularizationApprovals />
      </TabPanel>
    </TabContext>
  )
}

export default AttendanceTabRouter
